{
  "Database": {
    "Provider": "PostgreSQL"
  },
  "Jwt": {
    "Issuer": "Kotlet",
    "Audience": "Kotlet",
    "AccessTokenMinutes": 15
  },
  "Auth": {
    "RefreshTokenDays": 30,
    "RefreshTokenCookieName": "kotlet_refresh"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
